{
  "name": "tidesurf-core",
  "version": "0.1.0",
  "description": "Connect Chromium to LLM agents via token-efficient DOM compression",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tidesurf-core": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun vitest run test/unit",
    "test:integration": "bun vitest run test/integration",
    "test:bench": "bun vitest run test/bench --reporter=verbose",
    "test:all": "bun vitest run",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tidesurf/tidesurf-core"
  },
  "homepage": "https://tidesurf.github.io/tidesurf-core",
  "author": "TideSurf Contributors",
  "keywords": [
    "browser",
    "automation",
    "llm",
    "agent",
    "cdp",
    "chrome",
    "dom",
    "compression",
    "web",
    "scraping"
  ],
  "dependencies": {
    "chrome-remote-interface": "^0.33.2"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "elysia": "^1.4.27",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "license": "Apache-2.0"
}

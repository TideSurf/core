{
  "name": "@tidesurf/core",
  "version": "0.3.4",
  "description": "Connect Chromium to LLM agents via token-efficient DOM compression",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tidesurf": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "llms.txt",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:mcp": "bunx tsc --noEmit -p mcp/tsconfig.json",
    "test": "bun vitest run test/unit",
    "test:integration": "bun vitest run test/integration",
    "test:bench": "bun vitest run test/bench --reporter=verbose",
    "test:all": "bun vitest run",
    "build:web:landing": "bun run --cwd website/landing build",
    "build:web:docs": "bun run --cwd website/docs build",
    "verify:release": "bun run typecheck && bun run typecheck:mcp && bun run test:all && bun run build && bun run build:web:landing && bun run build:web:docs && npm_config_cache=.tmp-npm-cache npm pack --dry-run",
    "demo": "bun run demo/serve.ts",
    "prepublishOnly": "bun run verify:release"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/TideSurf/core"
  },
  "homepage": "https://tidesurf.org",
  "publishConfig": {
    "access": "public"
  },
  "author": "TideSurf Contributors",
  "keywords": [
    "browser",
    "automation",
    "llm",
    "agent",
    "cdp",
    "chrome",
    "dom",
    "compression",
    "web",
    "scraping"
  ],
  "dependencies": {
    "chrome-remote-interface": "^0.33.2"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^22.0.0",
    "elysia": "^1.4.27",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "license": "Apache-2.0"
}
